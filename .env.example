# Firebase web config — publishable; safe to ship in client bundle.
# Real security comes from Firestore rules + Authorized Domains.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional — when set, the real Google Maps replaces the stub MapView.
# Restrict the key to your published domain in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=
