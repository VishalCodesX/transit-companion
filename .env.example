# Development template only.
# Copy these values to .env for local development.
# Firebase web config is publishable; real security comes from Firestore rules + Authorized Domains.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Map uses Leaflet + OpenStreetMap tiles. No API key is required.
